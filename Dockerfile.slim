# syntax=docker/dockerfile:1
# Slim, core-only omnex image: the byte-exact T0/T1 retriever with no extras.
# Build context is the repo root (kept minimal by .dockerignore). Mount a corpus
# at runtime, e.g. `docker run --rm -v "$PWD:/work:ro" omnex:slim query ...`.

FROM ghcr.io/astral-sh/uv:python3.12-bookworm-slim AS build
ENV UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy \
    UV_PYTHON_DOWNLOADS=never
WORKDIR /src
COPY pyproject.toml README.md LICENSE ./
COPY src ./src
# Install omnex and its core deps (networkx/tiktoken/click) into a self-contained
# venv we copy into the runtime stage. No extras: this is the core install.
RUN uv venv /opt/omnex \
 && VIRTUAL_ENV=/opt/omnex uv pip install --no-cache .

FROM python:3.12-slim-bookworm AS runtime
LABEL org.opencontainers.image.source="https://github.com/Mathews-Tom/omnex"
LABEL org.opencontainers.image.description="omnex core (slim): structure-aware retrieval at a fraction of the tokens."
COPY --from=build /opt/omnex /opt/omnex
ENV PATH="/opt/omnex/bin:$PATH"
# Run as an unprivileged user; the container only reads mounted corpora.
RUN useradd --create-home --uid 1000 omnex
USER omnex
WORKDIR /work
ENTRYPOINT ["omnex"]
CMD ["--help"]
